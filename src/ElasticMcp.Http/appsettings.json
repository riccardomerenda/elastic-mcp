{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://localhost:5000",
  "ElasticMcp": {
    "Nodes": ["http://localhost:9200"],
    "Authentication": {
      "Type": "None"
    },
    "ReadOnly": true,
    "MaxResultSize": 100,
    "QueryTimeout": "30s"
  }
}
